@model IEnumerable<ExpenseTracker.Models.Expense>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">

    <!-- ================= HEADER ================= -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-0">Dashboard</h2>
            <small class="text-muted">
                Welcome, <strong>@ViewBag.UserName</strong> |
                Phone: @ViewBag.PhoneNumber
            </small>
        </div>

        <div class="d-flex flex-wrap gap-2">

            <a asp-controller="Expenses" asp-action="Create"
               class="btn btn-primary shadow-sm">
                Add Expense
            </a>

            <a asp-controller="Expenses" asp-action="Analytics"
               class="btn btn-outline-success shadow-sm">
                Analytics
            </a>

            <a asp-controller="Categories" asp-action="Index"
               class="btn btn-outline-dark shadow-sm">
                Categories
            </a>

            <a asp-controller="Expenses" asp-action="SetBudget"
               class="btn btn-outline-warning shadow-sm">
                Budget
            </a>

            <a asp-controller="Expenses" asp-action="ExportCsv"
               class="btn btn-outline-secondary shadow-sm">
                Export
            </a>

            <form asp-controller="Auth" asp-action="Logout" method="post">
                <button class="btn btn-outline-danger shadow-sm">
                    Logout
                </button>
            </form>

        </div>
    </div>


    <!-- ================= FILTER ================= -->

    <form method="get" asp-action="Index" class="row g-3 mb-4">

        <div class="col-md-3">
            <input type="text"
                   name="search"
                   class="form-control shadow-sm"
                   placeholder="Search description..." />
        </div>

        <div class="col-md-3">
            <select name="categoryId" class="form-control shadow-sm">
                <option value="">All Categories</option>

                @foreach (var category in ViewBag.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }

            </select>
        </div>

        <div class="col-md-2">
            <input type="date"
                   name="startDate"
                   class="form-control shadow-sm" />
        </div>

        <div class="col-md-2">
            <input type="date"
                   name="endDate"
                   class="form-control shadow-sm" />
        </div>

        <div class="col-md-2 d-grid">
            <button class="btn btn-info text-white shadow-sm">
                Filter
            </button>
        </div>

    </form>


    <!-- ================= BUDGET ================= -->

    <div class="card shadow border-0 mb-4 dashboard-card">

        <div class="card-body">

            <h5 class="mb-3">Monthly Budget</h5>

            <p>
                Budget: ₹ <strong>@ViewBag.Budget</strong> |
                Spent: ₹ <strong>@ViewBag.MonthlySpent</strong> |
                Remaining: ₹ <strong>@ViewBag.Remaining</strong>
            </p>

            <div class="progress rounded-pill mt-3" style="height:24px;">

                <div class="progress-bar progress-bar-striped progress-bar-animated
                    @(Convert.ToDouble(ViewBag.BudgetPercent) > 85 ? "bg-danger" : "bg-success")"
                     role="progressbar"
                     style="width:@(Math.Round(Convert.ToDouble(ViewBag.Percentage)))%">

                    @Math.Round(Convert.ToDouble(ViewBag.Percentage))%

                </div>

            </div>

            @if (Convert.ToDouble(ViewBag.BudgetPercent) > 85)
            {
                <div class="alert alert-danger mt-3">
                    Budget warning! You have used @ViewBag.BudgetPercent% of your budget.
                </div>
            }

        </div>

    </div>


    <!-- ================= STATS ================= -->

    <div class="row mb-4">
            <!-- Top Category -->
            <div class="col-md-4">
                <div class="card stat-card bg-primary text-white text-center">

                    <div class="card-body">

                        <h6>Top Category</h6>

                        <h4 class="fw-bold">
                            @ViewBag.TopCategory
                        </h4>

                        <p>
                            ₹ @ViewBag.TopCategoryAmount
                        </p>

                    </div>

                </div>
            </div>


            <!-- Total Transactions -->
            <div class="col-md-4">
                <div class="card stat-card bg-success text-white text-center">

                    <div class="card-body">

                        <h6>Total Transactions</h6>

                        <h3 class="fw-bold">
                            @ViewBag.TotalTransactions
                        </h3>

                    </div>

                </div>
            </div>


            <!-- Average Expense -->
            <div class="col-md-4">
                <div class="card stat-card bg-warning text-white text-center">

                    <div class="card-body">

                        <h6>Average Expense</h6>

                        <h3 class="fw-bold">
                            ₹ @ViewBag.AverageExpense
                        </h3>

                    </div>

                </div>
            </div>

        </div>
    </div>

    <!-- ================= RECENT ACTIVITY ================= -->

    <div class="card shadow border-0 mb-4 dashboard-card">

        <div class="card-body">

            <h5 class="mb-3">Recent Activity</h5>

            <ul class="list-group list-group-flush small">

                @foreach (var exp in ViewBag.RecentExpenses)
                {

                    <li class="list-group-item d-flex justify-content-between align-items-center">

                        <span>
                            <strong>@exp.Description</strong>
                        </span>

                        <span class="badge bg-light text-dark">
                            ₹ @exp.Amount
                        </span>

                    </li>

                }

            </ul>

        </div>

    </div>


    <!-- ================= TABLE ================= -->

    <table class="table table-hover table-bordered shadow-sm">

        <thead class="table-dark text-center">

            <tr>
                <th>Description</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>

        </thead>

        <tbody class="text-center align-middle">

            @foreach (var expense in Model)
            {

                <tr>

                    <td>@expense.Description</td>

                    <td>@expense.Category?.Name</td>

                    <td>₹ @expense.Amount</td>

                    <td>@expense.Date.ToShortDateString()</td>

                    <td>

                        <div class="d-flex justify-content-center gap-2">

                            <a asp-controller="Expenses"
                               asp-action="Details"
                               asp-route-id="@expense.Id"
                               class="btn btn-sm btn-info">
                                Details
                            </a>

                            <a asp-controller="Expenses"
                               asp-action="Edit"
                               asp-route-id="@expense.Id"
                               class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <form asp-action="Delete"
                                  asp-route-id="@expense.Id"
                                  method="post">

                                <button type="submit"
                                        class="btn btn-sm btn-danger"
                                        onclick="return confirm('Are you sure?');">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }

        </tbody>
    </table>


    <!-- ================= PAGINATION ================= -->

    <nav class="mt-4">

        <ul class="pagination justify-content-center">

            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                        Prev
                    </a>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">
                        @i
                    </a>

                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                        Next
                    </a>
                </li>
            }
        </ul>
    </nav>
</div>