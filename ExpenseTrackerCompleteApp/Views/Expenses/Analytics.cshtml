@{
    ViewData["Title"] = "Expense Analytics";
}

<div class="d-flex justify-content-between align-items-center mb-4">

     
    <h2>Expense Analytics</h2>

    <a asp-controller="Expenses"
       asp-action="Index"
       class="btn"
       style="background: linear-gradient(90deg,#6c757d,#495057);
          color:white;
          border-radius:8px;
          padding:8px 18px;">
        ← Back to Dashboard
    </a>
     

</div>

<div class="row mb-4 align-items-stretch">
    <div class="col-md-3">
        <div class="card shadow-sm text-center h-100" style="border-radius:12px;">
            <div class="card-body d-flex flex-column justify-content-center">
                <h5>Total Expenses</h5>
                <h3 class="text-primary">₹ @ViewBag.TotalExpense</h3>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card shadow-sm h-100" style="border-radius:12px;">
            <div class="card-body">
                <h5 class="text-center">Monthly Expenses</h5>
                <canvas id="monthlyChart" style="max-height:250px;"></canvas>
            </div>
        </div>
    </div>
     

</div>

<div class="row justify-content-center">

     
    <div class="col-md-5">
        <div class="card shadow-sm" style="border-radius:12px;">
            <div class="card-body">
                <h5 class="text-center">Category Spending</h5>
                <canvas id="categoryChart" style="max-height:300px;"></canvas>
            </div>
        </div>
    </div>
     

</div>

@section Scripts {

    <script>

        const monthLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthLabels));
        const monthTotals = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthTotals));

        new Chart(document.getElementById('monthlyChart'), {
            type: 'line',
            data: {
                labels: monthLabels,
                datasets: [{
                    label: 'Monthly Expense',
                    data: monthTotals,
                    borderWidth: 3
                }]
            }
        });

        const categoryLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CategoryLabels));
        const categoryTotals = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CategoryTotals));

        new Chart(document.getElementById('categoryChart'), {
            type: 'pie',
            data: {
                labels: categoryLabels,
                datasets: [{
                    data: categoryTotals
                }]
            }
        });

    </script>

}
